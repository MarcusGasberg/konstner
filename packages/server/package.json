{
  "name": "@konstner/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/sidecar.ts",
  "types": "./dist/sidecar.d.ts",
  "exports": {
    "./sidecar": {
      "types": "./dist/sidecar.d.ts",
      "development": "./src/sidecar.ts",
      "import": "./dist/sidecar.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "development": "./src/mcp.ts",
      "import": "./dist/mcp.js"
    },
    "./adapters/svelte-rewrite": {
      "types": "./dist/adapters/svelte-rewrite.d.ts",
      "development": "./src/adapters/svelte-rewrite.ts",
      "import": "./dist/adapters/svelte-rewrite.js"
    },
    "./providers/claude": {
      "types": "./dist/providers/claude.d.ts",
      "development": "./src/providers/claude.ts",
      "import": "./dist/providers/claude.js"
    },
    "./providers/opencode": {
      "types": "./dist/providers/opencode.d.ts",
      "development": "./src/providers/opencode.ts",
      "import": "./dist/providers/opencode.js"
    }
  },
  "bin": {
    "konstner-mcp": "./bin/konstner-mcp.js"
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@konstner/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "magic-string": "^0.30.11",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
